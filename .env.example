# ══════════════════════════════════════
# Application Laravel
# ══════════════════════════════════════
APP_NAME=SkillHub
APP_ENV=production

# APP_KEY à générer avec la commande : php artisan key:generate --show
APP_KEY=

APP_DEBUG=false
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

# ══════════════════════════════════════
# Logs
# ══════════════════════════════════════
LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ══════════════════════════════════════
# MySQL
# ─────────────────────────────────────
# DB_HOST doit être "db" dans Docker (nom du service docker-compose)
# et "127.0.0.1" en local sans Docker
# ══════════════════════════════════════
DB_CONNECTION=mysql
DB_HOST=db
DB_PORT=3306
DB_DATABASE=skillhub_db
DB_USERNAME=skillhub_user
DB_PASSWORD=change_me

# Variables utilisées par le container MySQL dans docker-compose
MYSQL_ROOT_PASSWORD=change_me
MYSQL_DATABASE=skillhub_db
MYSQL_USER=skillhub_user
MYSQL_PASSWORD=change_me

# ══════════════════════════════════════
# MongoDB
# ─────────────────────────────────────
# MONGODB_HOST doit être "mongodb" dans Docker
# et "127.0.0.1" en local sans Docker
# ══════════════════════════════════════
MONGODB_URI=mongodb://mongo_user:change_me@mongodb:27017/skillhub_logs?authSource=admin
MONGODB_HOST=mongodb
MONGODB_PORT=27017
MONGODB_DATABASE=skillhub_logs
MONGODB_USERNAME=mongo_user
MONGODB_PASSWORD=change_me
MONGODB_AUTH_DATABASE=admin

# ══════════════════════════════════════
# JWT
# ══════════════════════════════════════
# JWT_SECRET à générer avec la commande : php artisan jwt:secret
JWT_SECRET=

# ══════════════════════════════════════
# Session / Cache / Queue
# ══════════════════════════════════════
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database

# ══════════════════════════════════════
# Memcached
# ══════════════════════════════════════
MEMCACHED_HOST=127.0.0.1

# ══════════════════════════════════════
# Redis
# ══════════════════════════════════════
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# ══════════════════════════════════════
# Mail
# ══════════════════════════════════════
MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# ══════════════════════════════════════
# AWS
# ══════════════════════════════════════
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# ══════════════════════════════════════
# Vite
# ══════════════════════════════════════
VITE_APP_NAME="${APP_NAME}"
VITE_API_BASE_URL=http://localhost:8000